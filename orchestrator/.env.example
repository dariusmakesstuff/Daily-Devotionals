# Database — local dev without Docker (default in code):
# DATABASE_URL=sqlite:///./wwm_dev.db
# Docker Postgres:
DATABASE_URL=postgresql+psycopg://wwm:wwm@localhost:5433/wwm_orchestrator

# Redis for Arq worker (not needed when SYNC_WORKER=true)
REDIS_URL=redis://localhost:6380/0

# true = run pipeline in API thread (dev only; POST /runs waits until done)
SYNC_WORKER=true

API_HOST=0.0.0.0
API_PORT=8000

# false = fully automated runner (no Slack/script approval wait)
REQUIRE_HUMAN_APPROVAL=false

LOG_LEVEL=INFO
