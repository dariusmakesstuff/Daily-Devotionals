# Copy this file to .env and fill in your values
# .env is gitignored — never commit real credentials

# --- n8n database (Neon PostgreSQL) ---
DB_TYPE=postgresdb
DB_POSTGRESDB_HOST=
DB_POSTGRESDB_PORT=5432
DB_POSTGRESDB_DATABASE=
DB_POSTGRESDB_USER=
DB_POSTGRESDB_PASSWORD=
DB_POSTGRESDB_SSL_ENABLED=true
DB_POSTGRESDB_SSL_REJECT_UNAUTHORIZED=false

# --- n8n general ---
N8N_SECURE_COOKIE=false
TZ=America/New_York
GENERIC_TIMEZONE=America/New_York
MEDIA_WORKER_URL=http://media-worker:8000

# --- n8n public URL ---
WEBHOOK_URL=http://walkwithmedevotions.cloud-ip.cc:5678/
N8N_HOST=walkwithmedevotions.cloud-ip.cc
N8N_PORT=5678
N8N_PROTOCOL=http

# --- Worker URLs (all served by the media-worker container on the same Docker network) ---
FFMPEG_WORKER_URL=http://media-worker:8000
WHISPER_WORKER_URL=http://media-worker:8000

